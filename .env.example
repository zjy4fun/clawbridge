# ClawBridge Configuration

# 1. Access Key (Magic Link Password)
# You will use this to login: https://your-domain.com/?key=your_secret_password
ACCESS_KEY=change_me_to_something_secure

# 2. Cloudflare Tunnel Token
# Get this from Cloudflare Zero Trust Dashboard -> Networks -> Tunnels
# Format: eyJhIjoi... (Long Base64 string)
TUNNEL_TOKEN=eyJhIjoi...

# 3. Tunnel Mode
# Set to true if you want Node.js to manage the tunnel (Simple mode)
# Set to false if you use Systemd to manage the tunnel (Production mode)
ENABLE_EMBEDDED_TUNNEL=false
