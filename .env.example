# ClawBridge Dashboard Configuration

# 1. Security (Required)
# A random secret string to access the dashboard. 
# The installer generates this automatically.
ACCESS_KEY=change_me_to_a_secure_random_string

# 2. Network (Optional)
PORT=3000

# 3. Remote Access (Cloudflare Tunnel)
# Leave empty for Quick Tunnel (Temporary URL).
# Paste a Cloudflare Tunnel Token here for a permanent URL.
TUNNEL_TOKEN=

# Enable embedded 'cloudflared' tunnel management?
# true: The dashboard manages the tunnel process.
# false: You manage the tunnel externally.
ENABLE_EMBEDDED_TUNNEL=false

# 4. Advanced (Optional)
# Override path to OpenClaw if not found in PATH
# OPENCLAW_PATH=/root/.nvm/versions/node/v22.22.0/bin/openclaw
